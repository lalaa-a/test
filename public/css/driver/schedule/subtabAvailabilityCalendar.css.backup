/* Driver Availability Calendar Styles */
.availability-calendar-container {
    max-width: min(1400px, 95vw);
    margin: 0 auto;
    padding: 20px;
}

/* Page Header */
.page-header {
    padding: 20px;
    max-width: min(1400px, 95vw);
    margin: 0 auto;
    margin-top: 20px;
}

.page-header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
}

.page-title-section {
    flex: 1;
    min-width: 250px;
}

.page-title {
    font-family: 'Geologica', sans-serif;
    font-weight: 700;
    font-size: 32px;
    color: var(--primary, #006a71);
    margin: 0 0 8px 0;
}

.page-subtitle {
    font-family: 'Roboto', sans-serif;
    font-size: 16px;
    color: #6b7280;
    margin: 0;
}

.header-actions {
    display: flex;
    gap: 15px;
    align-items: center;
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: white;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 106, 113, 0.08);
    display: flex;
    align-items: center;
    gap: 15px;
    transition: transform 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-2px);
}

.stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: var(--primary, #006a71);
}

.stat-icon.available {
    background: linear-gradient(135deg, #e8f5e8 0%, #c8e6c9 100%);
    color: #2e7d32;
}

.stat-icon.unavailable {
    background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
    color: #c62828;
}

.stat-icon.total {
    background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
    color: #7b1fa2;
}

.stat-icon.percentage {
    background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
    color: #f57c00;
}

.stat-content {
    flex: 1;
}

.stat-number {
    font-family: 'Geologica', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--primary, #006a71);
    margin-bottom: 5px;
}

.stat-label {
    color: #6b7280;
    font-size: 0.9rem;
}

/* Calendar Legend */
.calendar-legend {
    display: flex;
    justify-content: center;
    gap: 30px;
    margin-bottom: 30px;
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: #374151;
}

.legend-color {
    width: 16px;
    height: 16px;
    border-radius: 4px;
}

.legend-color.available {
    background: linear-gradient(135deg, #E8F5E8 0%, #D4EDDA 100%);
    border: 1px solid #28a745;
}

.legend-color.unavailable {
    background: #f44336;
}

.legend-color.today {
    background: #00D4AA;
    border: 2px solid #00D4AA;
    box-shadow: 0 0 0 2px rgba(0, 212, 170, 0.3);
}

.legend-color.past {
    background: linear-gradient(135deg, #F1F3F4 0%, #E8EAED 100%);
    border: 1px solid #5F6368;
}

/* Calendar Container */
.calendar-container {
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 106, 113, 0.12), 0 2px 8px rgba(0, 106, 113, 0.08);
    padding: min(30px, 4vw);
    margin-bottom: 30px;
    border: 1px solid rgba(0, 106, 113, 0.1);
    backdrop-filter: blur(10px);
}

.calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 2px solid linear-gradient(90deg, #006a71 0%, #008891 50%, #006a71 100%);
    border-image: linear-gradient(90deg, #006a71 0%, #008891 50%, #006a71 100%) 1;
}

.calendar-nav-btn {
    background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
    border: 2px solid rgba(0, 106, 113, 0.2);
    padding: 12px 16px;
    border-radius: 12px;
    cursor: pointer;
    color: var(--primary, #006a71);
    font-size: 1.2rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 106, 113, 0.1);
}

.calendar-nav-btn:hover:not(:disabled) {
    background: linear-gradient(135deg, #006a71 0%, #008891 100%);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 106, 113, 0.3);
}

.calendar-nav-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.calendar-title {
    font-family: 'Geologica', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--primary, #006a71);
    margin: 0;
    text-shadow: 0 1px 2px rgba(0, 106, 113, 0.1);
}

/* Calendar Grid */
.calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: min(12px, 1.5vw);
    margin-top: 10px;
}

.calendar-day {
    min-height: min(60px, 8vw);
    max-height: 80px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    font-weight: 600;
    font-size: min(1rem, 3vw);
    position: relative;
    border: 2px solid transparent;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(5px);
}

.calendar-day:hover:not(.past):not(.calendar-day-name) {
    transform: translateY(-3px) scale(1.08);
    box-shadow: 0 8px 25px rgba(0, 106, 113, 0.25);
    z-index: 10;
}

.calendar-day.available {
    background: linear-gradient(135deg, #E8F5E8 0%, #D4EDDA 100%);
    color: #155724;
    box-shadow: 0 4px 15px rgba(40, 167, 69, 0.15);
    border: 1px solid rgba(40, 167, 69, 0.2);
}

.calendar-day.available:hover {
    background: linear-gradient(135deg, #D4EDDA 0%, #C3E6CB 100%);
    box-shadow: 0 6px 20px rgba(40, 167, 69, 0.25);
    border: 1px solid rgba(40, 167, 69, 0.3);
}

.calendar-day.unavailable {
    background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(244, 67, 54, 0.3);
}

.calendar-day.unavailable:hover {
    background: linear-gradient(135deg, #d32f2f 0%, #b71c1c 100%);
    box-shadow: 0 6px 20px rgba(244, 67, 54, 0.4);
}

.calendar-day.today {
    border-color: #00D4AA;
    box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.4), 0 4px 15px rgba(0, 212, 170, 0.2);
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% {
        box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.4), 0 4px 15px rgba(0, 212, 170, 0.2);
    }
    50% {
        box-shadow: 0 0 0 4px rgba(0, 212, 170, 0.6), 0 6px 20px rgba(0, 212, 170, 0.3);
    }
    100% {
        box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.4), 0 4px 15px rgba(0, 212, 170, 0.2);
    }
}

.calendar-day.past {
    background: linear-gradient(135deg, #F1F3F4 0%, #E8EAED 100%);
    color: #5F6368;
    cursor: not-allowed;
    opacity: 0.85;
    border: 1px solid rgba(95, 99, 104, 0.15);
    box-shadow: 0 2px 6px rgba(95, 99, 104, 0.08);
}

.calendar-day.past:hover {
    transform: none;
    box-shadow: 0 2px 8px rgba(95, 99, 104, 0.12);
    background: linear-gradient(135deg, #E8EAED 0%, #DADCE0 100%);
}

.calendar-day-name {
    background: linear-gradient(135deg, #006a71 0%, #008891 100%);
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    cursor: default;
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0, 106, 113, 0.3);
    height: 45px;
    aspect-ratio: unset;
}

.calendar-day-name:hover {
    transform: none;
    background: linear-gradient(135deg, #006a71 0%, #008891 100%);
    box-shadow: 0 6px 20px rgba(0, 106, 113, 0.4);
}

/* Quick Actions */
.quick-actions {
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 106, 113, 0.12), 0 2px 8px rgba(0, 106, 113, 0.08);
    padding: 30px;
    margin-bottom: 30px;
    border: 1px solid rgba(0, 106, 113, 0.1);
    backdrop-filter: blur(10px);
}

.action-group h3 {
    font-family: 'Geologica', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary, #006a71);
    margin: 0 0 20px 0;
    text-shadow: 0 1px 2px rgba(0, 106, 113, 0.1);
}

.action-buttons {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.btn-outline {
    padding: 10px 20px;
    border: 2px solid var(--primary, #006a71);
    background: linear-gradient(135deg, #ffffff 0%, #f0f4f8 100%);
    color: var(--primary, #006a71);
    border-radius: 12px;
    cursor: pointer;
    font-weight: 600;
    font-family: 'Geologica', sans-serif;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 106, 113, 0.1);
    display: flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.8rem;
}

.btn-outline:hover {
    background: linear-gradient(135deg, #006a71 0%, #008891 100%);
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 106, 113, 0.3);
    border-color: transparent;
}

/* Instructions */
.instructions-card {
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 106, 113, 0.12), 0 2px 8px rgba(0, 106, 113, 0.08);
    padding: 30px;
    border: 1px solid rgba(0, 106, 113, 0.1);
    backdrop-filter: blur(10px);
}

.instructions-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 25px;
}

.instructions-header i {
    color: var(--primary, #006a71);
    font-size: 1.4rem;
    background: linear-gradient(135deg, #006a71 0%, #008891 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.instructions-header h3 {
    font-family: 'Geologica', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--primary, #006a71);
    margin: 0;
    text-shadow: 0 1px 2px rgba(0, 106, 113, 0.1);
}

.instructions-content ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.instructions-content li {
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 106, 113, 0.1);
    color: #374151;
    font-size: 0.9rem;
    line-height: 1.6;
    display: flex;
    align-items: flex-start;
    gap: 10px;
}

.instructions-content li:before {
    content: "✓";
    color: #4caf50;
    font-weight: bold;
    font-size: 1rem;
    flex-shrink: 0;
}

.instructions-content li:last-child {
    border-bottom: none;
}

.instructions-content strong {
    color: var(--primary, #006a71);
    font-weight: 700;
}

/* Modal Styles */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
}

.modal.show {
    display: flex;
}

.modal-content {
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    border-radius: 20px;
    box-shadow: 0 25px 50px rgba(0, 106, 113, 0.25), 0 10px 25px rgba(0, 0, 0, 0.1);
    max-width: 500px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    border: 1px solid rgba(0, 106, 113, 0.1);
    animation: modalSlideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: translateY(-20px) scale(0.95);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.confirmation-modal {
    max-width: 450px;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 25px 30px;
    border-bottom: 2px solid linear-gradient(90deg, #006a71 0%, #008891 50%, #006a71 100%);
    border-image: linear-gradient(90deg, #006a71 0%, #008891 50%, #006a71 100%) 1;
}

.modal-header h3 {
    font-family: 'Geologica', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary, #006a71);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    text-shadow: 0 1px 2px rgba(0, 106, 113, 0.1);
}

.modal-close {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border: 2px solid rgba(0, 106, 113, 0.2);
    font-size: 1.5rem;
    cursor: pointer;
    color: #6b7280;
    padding: 8px;
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 106, 113, 0.1);
}

.modal-close:hover {
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    color: white;
    transform: rotate(90deg);
    box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
}

.modal-body {
    padding: 30px;
}

.confirmation-message {
    text-align: center;
}

.confirmation-icon {
    font-size: 3.5rem;
    background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 20px;
    filter: drop-shadow(0 2px 4px rgba(255, 193, 7, 0.3));
}

.confirmation-message p {
    font-size: 1.2rem;
    font-weight: 500;
    color: #374151;
    margin-bottom: 25px;
    line-height: 1.6;
}

.modal-footer {
    padding: 20px 30px 30px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(248, 249, 250, 0.8) 100%);
    backdrop-filter: blur(10px);
    display: flex;
    justify-content: center;
    gap: 15px;
}

.modal-btn {
    padding: 12px 30px;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    min-width: 120px;
}

.modal-btn.cancel {
    background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(108, 117, 125, 0.3);
}

.modal-btn.cancel:hover {
    background: linear-gradient(135deg, #5a6268 0%, #495057 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
}

.modal-btn.confirm {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);
}

.modal-btn.confirm:hover {
    background: linear-gradient(135deg, #20c997 0%, #17a2b8 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(40, 167, 69, 0.4);
}

/* Responsive Design */
@media (max-width: 768px) {
    .calendar-container {
        margin: 15px;
        padding: 20px;
    }

    .calendar-header {
        flex-direction: column;
        gap: 15px;
        text-align: center;
    }

    .calendar-title {
        font-size: 1.8rem;
    }

    .stats-grid {
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .calendar-grid {
        grid-template-columns: repeat(7, 1fr);
        gap: 8px;
    }

    .calendar-day {
        min-height: 50px;
        padding: 8px;
        font-size: 0.9rem;
    }

    .quick-actions {
        flex-direction: column;
        gap: 10px;
    }

    .action-btn {
        width: 100%;
        padding: 12px;
    }

    .instructions-card {
        padding: 20px;
    }

    .instructions-list {
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .modal-content {
        margin: 20px;
        width: calc(100% - 40px);
        max-width: none;
    }

    .modal-body {
        padding: 20px;
    }

    .modal-footer {
        padding: 15px 20px 20px;
        flex-direction: column;
        gap: 10px;
    }

    .modal-btn {
        width: 100%;
    }
}

@media (max-width: 480px) {
    .calendar-container {
        margin: 10px;
        padding: 15px;
    }

    .calendar-title {
        font-size: 1.5rem;
    }

    .calendar-subtitle {
        font-size: 0.9rem;
    }

    .stats-card {
        padding: 15px;
    }

    .stats-number {
        font-size: 1.8rem;
    }

    .calendar-grid {
        gap: 5px;
    }

    .calendar-day {
        min-height: 45px;
        padding: 6px;
        font-size: 0.8rem;
    }

    .instructions-card h3 {
        font-size: 1.2rem;
    }
}

.availability-summary {
    background: #f8f9fa;
    border-radius: 8px;
    padding: 15px;
    margin-top: 20px;
}

.summary-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 0;
}

.summary-item:not(:last-child) {
    border-bottom: 1px solid #e9ecef;
}

.summary-label {
    font-weight: 500;
    color: #6b7280;
}

.summary-value {
    font-weight: 600;
    color: var(--primary, #006a71);
}

.modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 15px;
    padding: 20px 25px;
    border-top: 1px solid #e9ecef;
}

/* Button Styles */
.btn-primary {
    background: var(--primary, #006a71);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-family: 'Geologica', sans-serif;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.btn-primary:hover {
    background: #005a5f;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 106, 113, 0.3);
}

.btn-secondary {
    background: #6c757d;
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    font-family: 'Geologica', sans-serif;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.btn-secondary:hover {
    background: #5a6268;
    transform: translateY(-2px);
}

/* Responsive Design */
@media (max-width: 768px) {
    .availability-calendar-container {
        padding: 10px;
    }

    .calendar-container {
        padding: 15px;
        margin: 10px;
    }

    .calendar-grid {
        gap: 6px;
    }

    .calendar-day {
        min-height: 50px;
        font-size: 0.9rem;
    }

    .calendar-day-name {
        height: 35px;
        font-size: 0.8rem;
    }

    .page-header-content {
        flex-direction: column;
        align-items: flex-start;
    }

    .header-actions {
        width: 100%;
        justify-content: space-between;
    }

    .stats-grid {
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    .calendar-legend {
        gap: 15px;
    }

    .action-buttons {
        flex-direction: column;
    }

    .action-buttons button {
        width: 100%;
        justify-content: center;
    }

    .modal-content {
        margin: 20px;
        width: calc(100% - 40px);
    }
}

@media (max-width: 480px) {
    .availability-calendar-container {
        padding: 5px;
    }

    .calendar-container {
        padding: 10px;
        margin: 5px;
    }

    .calendar-header {
        flex-direction: column;
        gap: 15px;
        text-align: center;
    }

    .calendar-title {
        font-size: 1.8rem;
    }

    .calendar-subtitle {
        font-size: 0.9rem;
    }

    .stats-grid {
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .calendar-grid {
        gap: 4px;
    }

    .calendar-day {
        min-height: 45px;
        padding: 8px;
        font-size: 0.8rem;
    }

    .calendar-day-name {
        height: 30px;
        font-size: 0.7rem;
    }

    .quick-actions {
        flex-direction: column;
        gap: 10px;
    }

    .action-btn {
        width: 100%;
        padding: 12px;
    }

    .instructions-card {
        padding: 20px;
    }

    .instructions-list {
        grid-template-columns: 1fr;
        gap: 15px;
    }

    .modal-content {
        margin: 20px;
        width: calc(100% - 40px);
        max-width: none;
    }

    .modal-body {
        padding: 20px;
    }

    .modal-footer {
        padding: 15px 20px 20px;
        flex-direction: column;
        gap: 10px;
    }

    .modal-btn {
        width: 100%;
    }
